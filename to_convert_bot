FORMAT_NAMES = {
    "word": {"ru": "Word (.docx)", "en": "Word (.docx)"},
    "pdf": {"ru": "PDF (.pdf)", "en": "PDF (.pdf)"},
}

FORMAT_EXTENSIONS = {
    "word": ".docx",
    "pdf": ".pdf",
}


def tr(lang: str, key: str, **kwargs) -> str:
    return TEXTS[key][lang].format(**kwargs)


def get_language_keyboard() -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup(
        inline_keyboard=[
            [
                InlineKeyboardButton(text="Русский", callback_data="lang:ru"),
                InlineKeyboardButton(text="English", callback_data="lang:en"),
            ]
        ]
    )


def get_source_format_keyboard(lang: str) -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup(
        inline_keyboard=[
            [
                InlineKeyboardButton(
                    text=FORMAT_NAMES["word"][lang],
                    callback_data="source:word",
                )
            ],
            [
                InlineKeyboardButton(
                    text=FORMAT_NAMES["pdf"][lang],
                    callback_data="source:pdf",
                )
            ],
        ]
    )


def get_target_format_keyboard(source_format: str, lang: str) -> InlineKeyboardMarkup:
    target_format = "pdf" if source_format == "word" else "word"
    return InlineKeyboardMarkup(
        inline_keyboard=[
            [
                InlineKeyboardButton(
                    text=FORMAT_NAMES[target_format][lang],
                    callback_data=f"target:{target_format}",
                )
            ]
        ]
    )


def get_restart_conversion_keyboard(lang: str) -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup(
        inline_keyboard=[
            [
                InlineKeyboardButton(
                    text=tr(lang, "convert_another"),
                    callback_data="restart_conversion",
                )
            ]
        ]
    )


def normalize_extension(filename: str) -> str:
    return Path(filename or "").suffix.lower()


def get_soffice_path() -> str | None:
    for candidate in SOFFICE_CANDIDATES:
        if candidate and os.path.exists(candidate):
            return candidate
    return shutil.which("soffice")


def build_libreoffice_profile_uri(profile_dir: str) -> str:
    return f"file://{quote(os.path.abspath(profile_dir))}"


def convert_word_to_pdf(input_path: str, output_path: str, temp_dir: str) -> None:
    soffice_path = get_soffice_path()
    if not soffice_path:
        raise FileNotFoundError("LibreOffice soffice binary is not available.")

    output_dir = os.path.dirname(output_path)
    profile_dir = os.path.join(temp_dir, "libreoffice-profile")
    os.makedirs(profile_dir, exist_ok=True)

    command = [
        soffice_path,
        "--headless",
        f"-env:UserInstallation={build_libreoffice_profile_uri(profile_dir)}",
        "--convert-to",
        "pdf:writer_pdf_Export",
        "--outdir",
        output_dir,
        input_path,
    ]
    result = subprocess.run(
        command,
        check=False,
        capture_output=True,
        text=True,
        timeout=180,
    )
    expected_output = os.path.join(output_dir, f"{Path(input_path).stem}.pdf")

    if result.returncode != 0 or not os.path.exists(expected_output):
        raise RuntimeError(result.stderr.strip() or result.stdout.strip() or "LibreOffice conversion failed.")

    if expected_output != output_path:
        shutil.move(expected_output, output_path)


def convert_pdf_to_word(input_path: str, output_path: str) -> None:
    converter = Converter(input_path)
    try:
        converter.convert(output_path)
    finally:
        converter.close()

    if not os.path.exists(output_path):
        raise RuntimeError("pdf2docx did not create the output file.")


def convert_file(
    input_path: str,
    source_format: str,
    target_format: str,
    output_path: str,
    temp_dir: str,
) -> None:
    if source_format == "word" and target_format == "pdf":
        convert_word_to_pdf(input_path, output_path, temp_dir)
        return

    if source_format == "pdf" and target_format == "word":
        convert_pdf_to_word(input_path, output_path)
        return

    raise ValueError(f"Unsupported conversion: {source_format} -> {target_format}")


async def cleanup_user_workspace(state: FSMContext) -> None:
    data = await state.get_data()
    temp_dir = data.get("temp_dir")

    if temp_dir and os.path.isdir(temp_dir):
        shutil.rmtree(temp_dir, ignore_errors=True)


async def start_handler(message: Message, state: FSMContext) -> None:
    await cleanup_user_workspace(state)
    await state.clear()
    await state.set_state(ConverterStates.choosing_language)
    await message.answer(
        TEXTS["choose_language"]["ru"],
        reply_markup=get_language_keyboard(),
    )


async def show_source_format_step(target: Message | CallbackQuery, state: FSMContext, lang: str) -> None:
    await state.set_state(ConverterStates.choosing_source_format)
    message = target.message if isinstance(target, CallbackQuery) else target
    await message.answer(
        tr(lang, "choose_source_format"),
        reply_markup=get_source_format_keyboard(lang),
    )


async def restart_conversion_flow(callback: CallbackQuery, state: FSMContext) -> None:
    data = await state.get_data()
    lang = data.get("lang", "ru")
    await cleanup_user_workspace(state)
    await state.clear()
    await state.update_data(lang=lang)
    await show_source_format_step(callback, state, lang)
    await callback.answer()


dp = Dispatcher()
bot = Bot(BOT_TOKEN) if BOT_TOKEN else None


@dp.message(CommandStart())
async def on_start(message: Message, state: FSMContext) -> None:
    await start_handler(message, state)


@dp.callback_query(F.data.startswith("lang:"))
async def on_language_chosen(callback: CallbackQuery, state: FSMContext) -> None:
    lang = callback.data.split(":", 1)[1]
    await state.update_data(lang=lang)
    await callback.message.answer(tr(lang, "language_saved"))
    await show_source_format_step(callback, state, lang)
    await callback.answer()


@dp.callback_query(F.data.startswith("source:"))
async def on_source_format_chosen(callback: CallbackQuery, state: FSMContext) -> None:
    source_format = callback.data.split(":", 1)[1]
    data = await state.get_data()
    lang = data.get("lang", "ru")

    await cleanup_user_workspace(state)
    temp_dir = tempfile.mkdtemp(prefix="converter_bot_")
    await state.update_data(
        source_format=source_format,
        temp_dir=temp_dir,
        input_path=None,
        original_filename=None,
    )
    await state.set_state(ConverterStates.waiting_for_file)

    await callback.message.answer(
        tr(
            lang,
            "upload_source_file",
            format_name=FORMAT_NAMES[source_format][lang],
        )
    )
    await callback.answer()


@dp.callback_query(F.data == "restart_conversion")
async def on_restart_conversion(callback: CallbackQuery, state: FSMContext) -> None:
    await restart_conversion_flow(callback, state)


@dp.message(ConverterStates.waiting_for_file, F.document)
async def on_file_uploaded(message: Message, state: FSMContext) -> None:
    data = await state.get_data()
    lang = data.get("lang", "ru")
    source_format = data["source_format"]
    expected_extension = FORMAT_EXTENSIONS[source_format]
    file_name = message.document.file_name or f"source{expected_extension}"
    file_extension = normalize_extension(file_name)

    if file_extension != expected_extension:
        await message.answer(
            tr(
                lang,
                "wrong_file_type",
                format_name=FORMAT_NAMES[source_format][lang],
            )
        )
        return

    temp_dir = data["temp_dir"]
    input_path = os.path.join(temp_dir, f"input{expected_extension}")
    telegram_file = await bot.get_file(message.document.file_id)
    await bot.download_file(telegram_file.file_path, destination=input_path)

    await state.update_data(
        input_path=input_path,
        original_filename=Path(file_name).stem,
    )
    await state.set_state(ConverterStates.choosing_target_format)

    await message.answer(
        f"{tr(lang, 'choose_target_format')}\n\n{tr(lang, 'formatting_note')}",
        reply_markup=get_target_format_keyboard(source_format, lang),
    )


@dp.message(ConverterStates.waiting_for_file)
async def on_non_document_received(message: Message, state: FSMContext) -> None:
    data = await state.get_data()
    lang = data.get("lang", "ru")
    await message.answer(tr(lang, "document_only"))


@dp.callback_query(ConverterStates.choosing_target_format, F.data.startswith("target:"))
async def on_target_format_chosen(callback: CallbackQuery, state: FSMContext) -> None:
    target_format = callback.data.split(":", 1)[1]
    data = await state.get_data()
    lang = data.get("lang", "ru")
    source_format = data["source_format"]
    input_path = data["input_path"]
    original_filename = data.get("original_filename") or "converted_file"
    temp_dir = data["temp_dir"]
    output_path = os.path.join(temp_dir, f"{original_filename}_converted{FORMAT_EXTENSIONS[target_format]}")

    await callback.message.answer(tr(lang, "converting"))

    try:
        convert_file(input_path, source_format, target_format, output_path, temp_dir)
    except FileNotFoundError:
        await callback.message.answer(
            f"{tr(lang, 'engine_missing_error')}\n\n{tr(lang, 'start_over')}",
            reply_markup=get_restart_conversion_keyboard(lang),
        )
        await cleanup_user_workspace(state)
        await state.clear()
        await state.update_data(lang=lang)
        await callback.answer()
        return
    except ValueError:
        await callback.message.answer(
            f"{tr(lang, 'empty_text_error')}\n\n{tr(lang, 'start_over')}",
            reply_markup=get_restart_conversion_keyboard(lang),
        )
        await cleanup_user_workspace(state)
        await state.clear()
        await state.update_data(lang=lang)
        await callback.answer()
        return
    except Exception:
        logging.exception("Conversion failed")
        await callback.message.answer(
            f"{tr(lang, 'conversion_error')}\n\n{tr(lang, 'start_over')}",
            reply_markup=get_restart_conversion_keyboard(lang),
        )
        await cleanup_user_workspace(state)
        await state.clear()
        await state.update_data(lang=lang)
        await callback.answer()
        return

    await callback.message.answer(tr(lang, "conversion_done"))
    await callback.message.answer_document(
        document=FSInputFile(output_path),
        caption=tr(lang, "result_caption"),
        reply_markup=get_restart_conversion_keyboard(lang),
    )

    await cleanup_user_workspace(state)
    await state.clear()
    await state.update_data(lang=lang)
    await callback.answer()


async def main() -> None:
    if not BOT_TOKEN:
        raise RuntimeError(
            "Bot token is not configured. Set FILE_CONVERTER_BOT_TOKEN or TELEGRAM_BOT_TOKEN, "
            "or put the token into BOT_TOKEN_FALLBACK."
        )

    logging.basicConfig(level=logging.INFO)
    try:
        await dp.start_polling(bot)
    except TelegramNetworkError as exc:
        raise RuntimeError(
            "Telegram API is unreachable from the current environment. "
            "Check internet access, DNS, proxy/VPN settings, or local firewall."
        ) from exc


if __name__ == "__main__":
    asyncio.run(main())
