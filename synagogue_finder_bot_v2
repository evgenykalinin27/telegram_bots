def build_nearest_synagogues_message(
    city_name: str,
    synagogues: list[SynagoguePlace],
    user_location: Location,
    lang: str,
) -> tuple[str, list[tuple[SynagoguePlace, float]]]:
    ranked_synagogues = sorted(
        synagogues,
        key=lambda synagogue: calculate_distance_km(
            user_location.latitude,
            user_location.longitude,
            synagogue.lat,
            synagogue.lon,
        ),
    )
    nearest_synagogues = [
        (
            synagogue,
            calculate_distance_km(
                user_location.latitude,
                user_location.longitude,
                synagogue.lat,
                synagogue.lon,
            ),
        )
        for synagogue in ranked_synagogues[:NEAREST_RESULTS]
    ]

    message = tr(lang, "nearest_list_header", city=city_name)
    return message, nearest_synagogues


def build_synagogue_details_message(
    synagogue: SynagoguePlace,
    distance_km: float | None,
    lang: str,
) -> str:
    phone = ""
    try:
        phone = fetch_place_phone(synagogue.place_id)
    except Exception:
        logging.exception("Failed to fetch place phone")

    if distance_km is None:
        distance_line = ""
    else:
        distance_prefix = {
            "ru": f"📏 Расстояние: {distance_km:.1f} км\n",
            "en": f"📏 Distance: {distance_km:.1f} km\n",
            "he": f"📏 מרחק: {distance_km:.1f} ק״מ\n",
        }[lang]
        distance_line = distance_prefix

    return tr(lang, "details_message", name=synagogue.name, distance_line=distance_line, phone=phone)


def get_cached_location(user_id: int) -> Location | None:
    cached = USER_LOCATION_CACHE.get(user_id)
    if not cached:
        return None

    if time.time() - cached["timestamp"] > LOCATION_CACHE_TTL_SECONDS:
        USER_LOCATION_CACHE.pop(user_id, None)
        return None

    return Location(latitude=cached["latitude"], longitude=cached["longitude"])


def save_cached_location(user_id: int, location: Location) -> None:
    USER_LOCATION_CACHE[user_id] = {
        "latitude": float(location.latitude),
        "longitude": float(location.longitude),
        "timestamp": time.time(),
    }


async def show_nearest_synagogues(
    message: Message,
    state: FSMContext,
    city_name: str,
    synagogues: list[SynagoguePlace],
    location: Location,
    lang: str,
) -> None:
    nearest_message, nearest_synagogues = build_nearest_synagogues_message(
        city_name,
        synagogues,
        location,
        lang,
    )
    await state.update_data(nearest_synagogues=serialize_nearest_synagogues(nearest_synagogues))
    await state.set_state(SynagogueFinderStates.choosing_city)
    await message.answer(
        nearest_message,
        reply_markup=get_nearest_synagogues_inline_keyboard(nearest_synagogues, lang),
        disable_web_page_preview=True,
    )
    await message.answer(" ", reply_markup=get_bottom_menu_keyboard(lang))


