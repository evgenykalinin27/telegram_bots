        reply_markup=get_bottom_menu_keyboard(),
    )


async def fetch_city_synagogues(message: Message, state: FSMContext, city_name: str) -> None:
    waiting_message = await message.answer(
        "Ищу актуальные синагоги. Это может занять несколько секунд.",
        reply_markup=get_bottom_menu_keyboard(),
    )

    try:
        synagogues = await asyncio.to_thread(fetch_synagogues_for_city, city_name)
    except Exception as error:
        logging.exception("Failed to fetch synagogues")
        await waiting_message.answer(
            build_fetch_error_message(error),
            reply_markup=get_bottom_menu_keyboard(),
        )
        return

    if not synagogues:
        await waiting_message.answer(
            "Google Places API не вернул синагоги для этого города. Попробуйте другой город или другую форму написания.",
            reply_markup=get_bottom_menu_keyboard(),
        )
        return

    await state.update_data(
        selected_city=city_name,
        synagogues=serialize_synagogues(synagogues),
    )
    await state.set_state(SynagogueFinderStates.deciding_location)
    await waiting_message.answer(
        "Хотите поделиться геопозицией, чтобы я показал 5 ближайших синагог?\n"
        "Поделиться геопозицией можно только с телефона.\n"
        "Нажмите кнопку «Отправить геопозицию» внизу или выберите общий список.",
        reply_markup=get_location_inline_keyboard(),
    )
    await waiting_message.answer(
        "Кнопка отправки геопозиции доступна в нижней панели.",
        reply_markup=get_share_location_keyboard(),
    )


