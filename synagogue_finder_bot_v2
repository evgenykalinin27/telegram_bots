async def fetch_city_synagogues(
    message: Message,
    state: FSMContext,
    city_name: str,
    lang: str,
    user_id: int,
) -> None:
    source = get_user_source(user_id)
    waiting_message = await message.answer(tr(lang, "searching"), reply_markup=get_bottom_menu_keyboard(lang))

    try:
        synagogues = await asyncio.to_thread(fetch_synagogues_for_city, city_name, source)
    except Exception as error:
        logging.exception("Failed to fetch synagogues")
        await waiting_message.answer(
            build_fetch_error_message(error, lang),
            reply_markup=get_bottom_menu_keyboard(lang),
        )
        return

    if not synagogues:
        await waiting_message.answer(
            tr(lang, "no_synagogues"),
            reply_markup=get_bottom_menu_keyboard(lang),
        )
        return

    await state.update_data(
        selected_city=city_name,
        synagogues=serialize_synagogues(synagogues),
    )

    cached_location = get_cached_location(user_id)
    if cached_location:
        await show_nearest_synagogues(message, state, city_name, synagogues, cached_location, lang)
        return

    await state.set_state(SynagogueFinderStates.deciding_location)
    await waiting_message.answer(tr(lang, "location_prompt"), reply_markup=get_location_inline_keyboard(lang))
    await message.answer(
        tr(lang, "send_location_hint"),
        reply_markup=get_share_location_keyboard(lang),
    )


