@dp.callback_query(F.data.startswith("stars:"))
async def handle_stars_invoice(callback: CallbackQuery, state: FSMContext) -> None:
    lang = get_user_language(callback.from_user.id)
    if callback.data == "stars:custom":
        await callback.answer()
        await state.set_state(SynagogueFinderStates.entering_stars_amount)
        await callback.message.answer(
            tr(lang, "stars_custom_amount_prompt"),
            reply_markup=get_bottom_menu_keyboard(lang),
        )
        return

    try:
        amount = int(callback.data.split(":", 1)[1])
    except (IndexError, ValueError):
        await callback.answer(tr(lang, "stars_payment_error"), show_alert=True)
        return

    await callback.answer()
    try:
        await send_stars_invoice(callback.message, lang, amount)
    except Exception:
        logging.exception("Failed to create Telegram Stars invoice")
        await callback.message.answer(
            tr(lang, "stars_payment_error"),
            reply_markup=get_bottom_menu_keyboard(lang),
        )


