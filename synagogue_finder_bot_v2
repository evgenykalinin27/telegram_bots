@dp.message()
async def handle_fallback(message: Message, state: FSMContext) -> None:
    lang = get_user_language(message.from_user.id)
    current_state = await state.get_state()
    if current_state == SynagogueFinderStates.entering_city_manually.state:
        await message.answer(
            tr(lang, "manual_city_fallback"),
            reply_markup=get_bottom_menu_keyboard(lang),
        )
        return

    if message.from_user.id not in USER_LANGUAGES:
        await state.set_state(SynagogueFinderStates.choosing_language)
        await message.answer(tr("ru", "choose_language"), reply_markup=get_language_keyboard())
        return

    if message.from_user.id not in USER_SOURCES:
        await show_source_selection(message, state, lang)
        return

    await show_city_selection(message, state, lang)


async def main() -> None:
    if not BOT_TOKEN:
        raise RuntimeError(
            "Bot token is not configured. Set SYNAGOGUE_BOT_TOKEN or TELEGRAM_BOT_TOKEN."
        )

    logging.basicConfig(level=logging.INFO)
    bot = Bot(token=BOT_TOKEN)
    await dp.start_polling(bot)


if __name__ == "__main__":
    asyncio.run(main())
