def normalize_city_name(city_name: str) -> str:
    normalized = city_name.strip().lower()
    aliases = {
        "москва": CITY_MOSCOW_ENGLISH.lower(),
        "moscow": CITY_MOSCOW_ENGLISH.lower(),
        "тель-авив": CITY_TEL_AVIV_ENGLISH.lower(),
        "тель авив": CITY_TEL_AVIV_ENGLISH.lower(),
        "tel aviv": CITY_TEL_AVIV_ENGLISH.lower(),
        "saint petersburg": CITY_SAINT_PETERSBURG_ENGLISH.lower(),
        "st petersburg": CITY_SAINT_PETERSBURG_ENGLISH.lower(),
        "st. petersburg": CITY_SAINT_PETERSBURG_ENGLISH.lower(),
        "санкт-петербург": CITY_SAINT_PETERSBURG_ENGLISH.lower(),
        "санкт петербург": CITY_SAINT_PETERSBURG_ENGLISH.lower(),
        "питер": CITY_SAINT_PETERSBURG_ENGLISH.lower(),
    }
    return aliases.get(normalized, city_name.strip())


def fetch_json(
    url: str,
    method: str = "GET",
    body: bytes | None = None,
    extra_headers: dict[str, str] | None = None,
) -> Any:
    headers = {
        "User-Agent": HTTP_USER_AGENT,
        "Accept": "application/json",
    }
    if extra_headers:
        headers.update(extra_headers)

    request = Request(
        url,
        data=body,
        method=method,
        headers=headers,
    )
    ssl_context = ssl.create_default_context(cafile=certifi.where())
    with urlopen(request, timeout=30, context=ssl_context) as response:
        return json.loads(response.read().decode("utf-8"))


def fetch_text(url: str) -> str:
    request = Request(
        url,
        headers={
            "User-Agent": HTTP_USER_AGENT,
            "Accept": "text/html,application/xhtml+xml",
        },
    )
    ssl_context = ssl.create_default_context(cafile=certifi.where())
    with urlopen(request, timeout=30, context=ssl_context) as response:
        html_text = response.read().decode("utf-8", errors="replace")

    if "Just a moment..." in html_text and "challenges.cloudflare.com" in html_text:
        raise RuntimeError("CHABAD_CLOUDFLARE_BLOCK")

    return html_text


def fetch_google_synagogues_for_city(city_name: str) -> list[SynagoguePlace]:
    if not GOOGLE_PLACES_API_KEY:
        raise RuntimeError("GOOGLE_PLACES_API_KEY_MISSING")

    normalized_city = normalize_city_name(city_name)
    search_city = CITY_SEARCH_QUERIES.get(normalized_city, normalized_city)
    payload = {
        "textQuery": f"synagogues in {search_city}",
        "includedType": "synagogue",
        "languageCode": "en",
        "maxResultCount": MAX_RESULTS,
    }
    response = fetch_json(
        GOOGLE_PLACES_TEXT_SEARCH_URL,
        method="POST",
        body=json.dumps(payload).encode("utf-8"),
        extra_headers={
            "Content-Type": "application/json",
            "X-Goog-Api-Key": GOOGLE_PLACES_API_KEY,
            "X-Goog-FieldMask": GOOGLE_PLACES_FIELD_MASK,
        },
    )

    places = response.get("places", [])
    if not places:
        return []

    unique_places: dict[str, SynagoguePlace] = {}
    for place in places:
        place_id = place.get("id")
        display_name = place.get("displayName", {})
        location = place.get("location", {})
        name = display_name.get("text")
        lat = location.get("latitude")
        lon = location.get("longitude")
        google_maps_url = place.get("googleMapsUri")

        if not place_id or not name or lat is None or lon is None:
            continue

        if not google_maps_url:
            google_maps_url = f"https://www.google.com/maps/search/?api=1&query={lat},{lon}"

        unique_places[name.casefold()] = SynagoguePlace(
            source="google",
            place_id=place_id,
            name=name,
            lat=float(lat),
            lon=float(lon),
            google_maps_url=google_maps_url,
        )

    return sorted(unique_places.values(), key=lambda place: place.name.lower())


def geocode_chabad_center(name: str, city_name: str) -> SynagoguePlace | None:
    if not GOOGLE_PLACES_API_KEY:
        raise RuntimeError("GOOGLE_PLACES_API_KEY_MISSING")

    normalized_city = normalize_city_name(city_name)
    search_city = CITY_SEARCH_QUERIES.get(normalized_city, normalized_city)
    payload = {
        "textQuery": f"{name}, {search_city}",
        "languageCode": "en",
        "maxResultCount": 1,
    }
    response = fetch_json(
        GOOGLE_PLACES_TEXT_SEARCH_URL,
        method="POST",
        body=json.dumps(payload).encode("utf-8"),
        extra_headers={
            "Content-Type": "application/json",
            "X-Goog-Api-Key": GOOGLE_PLACES_API_KEY,
            "X-Goog-FieldMask": GOOGLE_PLACES_FIELD_MASK,
        },
    )
    places = response.get("places", [])
    if not places:
        return None

    place = places[0]
    place_id = place.get("id")
    location = place.get("location", {})
    lat = location.get("latitude")
