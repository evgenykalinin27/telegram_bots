@dp.callback_query(F.data.startswith("synagogue:"))
async def handle_synagogue_details(callback: CallbackQuery, state: FSMContext) -> None:
    lang = get_user_language(callback.from_user.id)
    data = await state.get_data()
    nearest_synagogues = deserialize_nearest_synagogues(data.get("nearest_synagogues", []))

    try:
        synagogue_index = int(callback.data.split(":", 1)[1])
    except (IndexError, ValueError):
        await callback.answer(tr(lang, "open_failed"), show_alert=True)
        return

    if synagogue_index < 0 or synagogue_index >= len(nearest_synagogues):
        await callback.answer(tr(lang, "list_outdated"), show_alert=True)
        return

    synagogue, distance_km = nearest_synagogues[synagogue_index]
    await callback.answer()
    await callback.message.answer(
        build_synagogue_details_message(synagogue, distance_km, lang),
        reply_markup=get_synagogue_links_keyboard(synagogue, lang),
        disable_web_page_preview=True,
    )


