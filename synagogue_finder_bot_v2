def build_nearest_synagogues_message(
    city_name: str,
    synagogues: list[SynagoguePlace],
    user_location: Location,
) -> tuple[str, list[tuple[SynagoguePlace, float]]]:
    ranked_synagogues = sorted(
        synagogues,
        key=lambda synagogue: calculate_distance_km(
            user_location.latitude,
            user_location.longitude,
            synagogue.lat,
            synagogue.lon,
        ),
    )
    nearest_synagogues = [
        (
            synagogue,
            calculate_distance_km(
                user_location.latitude,
                user_location.longitude,
                synagogue.lat,
                synagogue.lon,
            ),
        )
        for synagogue in ranked_synagogues[:NEAREST_RESULTS]
    ]

    message = (
        f"Ближайшие синагоги в городе {city_name}:\n\n"
        "Выберите синагогу из списка ниже."
    )
    return message, nearest_synagogues


