@dp.callback_query(F.data == "location:skip")
async def handle_skip_location(callback: CallbackQuery, state: FSMContext) -> None:
    data = await state.get_data()
    city_name = data.get("selected_city", CITY_MOSCOW_ENGLISH)
    synagogues = deserialize_synagogues(data.get("synagogues", []))
    await callback.answer()
    await state.set_state(SynagogueFinderStates.choosing_city)
    await callback.message.answer(
        f"Актуальные синагоги в городе {city_name}:\n\nВыберите синагогу из списка ниже.",
        reply_markup=get_synagogues_inline_keyboard(synagogues),
    )
    await callback.message.answer(
        "Чтобы начать заново или открыть помощь, используйте кнопки ниже.",
        reply_markup=get_bottom_menu_keyboard(),
    )


@dp.message(SynagogueFinderStates.deciding_location, F.location)
async def handle_location(message: Message, state: FSMContext) -> None:
    data = await state.get_data()
    city_name = data.get("selected_city", CITY_MOSCOW_ENGLISH)
    synagogues = deserialize_synagogues(data.get("synagogues", []))
    nearest_message, nearest_synagogues = build_nearest_synagogues_message(
        city_name,
        synagogues,
        message.location,
    )
    await state.update_data(nearest_synagogues=serialize_nearest_synagogues(nearest_synagogues))
    await state.set_state(SynagogueFinderStates.choosing_city)
    await message.answer(
        nearest_message,
        reply_markup=get_nearest_synagogues_inline_keyboard(nearest_synagogues),
        disable_web_page_preview=True,
    )
    await message.answer(
        "Чтобы выбрать другой сценарий, используйте кнопки ниже.",
        reply_markup=get_bottom_menu_keyboard(),
    )


@dp.callback_query(F.data.startswith("synagogue:"))
async def handle_synagogue_details(callback: CallbackQuery, state: FSMContext) -> None:
    data = await state.get_data()
    nearest_synagogues = deserialize_nearest_synagogues(data.get("nearest_synagogues", []))

    try:
        synagogue_index = int(callback.data.split(":", 1)[1])
    except (IndexError, ValueError):
        await callback.answer("Не удалось открыть синагогу.", show_alert=True)
        return

    if synagogue_index < 0 or synagogue_index >= len(nearest_synagogues):
        await callback.answer("Список устарел. Выберите город заново.", show_alert=True)
        return

    synagogue, distance_km = nearest_synagogues[synagogue_index]
    await callback.answer()
    await callback.message.answer(
        build_synagogue_details_message(synagogue, distance_km),
        reply_markup=get_synagogue_links_keyboard(synagogue),
        disable_web_page_preview=True,
    )


@dp.callback_query(F.data.startswith("general_synagogue:"))
async def handle_general_synagogue_details(callback: CallbackQuery, state: FSMContext) -> None:
    data = await state.get_data()
    synagogues = deserialize_synagogues(data.get("synagogues", []))

    try:
        synagogue_index = int(callback.data.split(":", 1)[1])
    except (IndexError, ValueError):
        await callback.answer("Не удалось открыть синагогу.", show_alert=True)
        return

    if synagogue_index < 0 or synagogue_index >= len(synagogues):
        await callback.answer("Список устарел. Выберите город заново.", show_alert=True)
        return

    synagogue = synagogues[synagogue_index]
    await callback.answer()
    await callback.message.answer(
        synagogue.name,
        reply_markup=get_synagogue_links_keyboard(synagogue),
        disable_web_page_preview=True,
    )


