    if isinstance(error, RuntimeError) and str(error) == "GOOGLE_PLACES_API_KEY_MISSING":
        return {
            "ru": "Не задан GOOGLE_PLACES_API_KEY. Добавьте ключ Google Places API в переменные окружения.",
            "en": "GOOGLE_PLACES_API_KEY is not set. Add the Google Places API key to environment variables.",
            "he": "המשתנה GOOGLE_PLACES_API_KEY לא הוגדר. הוסף את מפתח Google Places API למשתני הסביבה.",
        }[lang]

    if isinstance(error, RuntimeError) and str(error) == "CHABAD_CLOUDFLARE_BLOCK":
        return {
            "ru": "Chabad.org блокирует автоматические запросы через Cloudflare, поэтому сейчас получить данные из этого источника не удается.",
            "en": "Chabad.org is blocking automated requests via Cloudflare, so the bot cannot currently fetch data from this source.",
