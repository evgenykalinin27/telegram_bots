def parse_chabad_center_urls(html_text: str) -> list[str]:
    matches = re.findall(
        r'href="(?P<href>(?:https://www\.chabad\.org)?/jewish-centers/\d+/[^"]+/Synagogue/[^"]+)"',
        html_text,
        flags=re.IGNORECASE,
    )
    seen: set[str] = set()
    urls: list[str] = []
    for href in matches:
        absolute_url = urljoin(CHABAD_BASE_URL, html.unescape(href))
        if absolute_url in seen:
            continue
        seen.add(absolute_url)
        urls.append(absolute_url)
    return urls[:MAX_CHABAD_RESULTS]


def parse_chabad_center_name(html_text: str, fallback_url: str) -> str:
    patterns = [
        r'<meta\s+property="og:title"\s+content="([^"]+)"',
        r"<title>\s*([^<]+?)\s*-\s*(?:Chabad House|Synagogue|Campus Chabad House|Hospitality Center)[^<]*</title>",
        r"<h1[^>]*>\s*([^<]+?)\s*</h1>",
    ]
    for pattern in patterns:
        match = re.search(pattern, html_text, flags=re.IGNORECASE)
        if match:
            return html.unescape(match.group(1)).strip()

    slug = fallback_url.rstrip("/").split("/")[-1]
    return slug.replace("-", " ").strip() or "Chabad Synagogue"


def parse_chabad_phone(html_text: str) -> str:
    phone_patterns = [
        r'href="tel:([^"]+)"',
        r"Phone:\s*</[^>]+>\s*([^<]+)",
    ]
    for pattern in phone_patterns:
        match = re.search(pattern, html_text, flags=re.IGNORECASE)
        if match:
            return html.unescape(match.group(1)).strip()
    return ""


def fetch_chabad_synagogues_for_city(city_name: str) -> list[SynagoguePlace]:
    normalized_city = normalize_city_name(city_name)
    search_city = CITY_SEARCH_QUERIES.get(normalized_city, normalized_city)
    search_url = f"{CHABAD_SEARCH_URL}?{urlencode({'query': search_city})}"
    search_html = fetch_text(search_url)
    center_urls = parse_chabad_center_urls(search_html)

    unique_places: dict[str, SynagoguePlace] = {}
    for center_url in center_urls:
        try:
            center_html = fetch_text(center_url)
            center_name = parse_chabad_center_name(center_html, center_url)
            phone = parse_chabad_phone(center_html)
            geocoded = geocode_chabad_center(center_name, city_name)
            if not geocoded:
                continue
            geocoded.phone = phone
            geocoded.source_url = center_url
            unique_places[geocoded.name.casefold()] = geocoded
        except Exception:
            logging.exception("Failed to parse Chabad center: %s", center_url)

    return sorted(unique_places.values(), key=lambda place: place.name.lower())


