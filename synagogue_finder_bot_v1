import asyncio
import json
import logging
import os
import socket
import ssl
from dataclasses import dataclass
from typing import Any
from urllib.parse import urlencode
from urllib.request import Request, urlopen
from urllib.error import HTTPError, URLError

from aiogram import Bot, Dispatcher, F
from aiogram.filters import CommandStart
from aiogram.fsm.context import FSMContext
from aiogram.fsm.state import State, StatesGroup
from aiogram.types import (
    CallbackQuery,
    InlineKeyboardButton,
    InlineKeyboardMarkup,
    KeyboardButton,
    Message,
    ReplyKeyboardMarkup,
)

import certifi


BOT_TOKEN = os.getenv("SYNAGOGUE_BOT_TOKEN") or os.getenv("TELEGRAM_BOT_TOKEN")
BOT_TOKEN_FALLBACK = ""
if not BOT_TOKEN and BOT_TOKEN_FALLBACK:
    BOT_TOKEN = BOT_TOKEN_FALLBACK

HELP_CONTACT = "@your_support_contact"
HTTP_USER_AGENT = "SynagogueFinderBot/1.0 (contact: @your_support_contact)"
NOMINATIM_SEARCH_URL = "https://nominatim.openstreetmap.org/search"
OVERPASS_API_URL = "https://overpass-api.de/api/interpreter"

CITY_MOSCOW = "Москва"
CITY_MOSCOW_ENGLISH = "Moscow"
MANUAL_CITY_BUTTON = "Ввести город самостоятельно"
RESTART_BUTTON = "Начать сначала"
HELP_BUTTON = "Помощь"
MAX_RESULTS = 15


class SynagogueFinderStates(StatesGroup):
    choosing_city = State()
    entering_city_manually = State()


@dataclass
class SynagoguePlace:
    name: str
    lat: float
    lon: float

    @property
    def google_maps_url(self) -> str:
        return f"https://www.google.com/maps/search/?api=1&query={self.lat},{self.lon}"

    @property
    def waze_url(self) -> str:
        return f"https://www.waze.com/ul?ll={self.lat},{self.lon}&navigate=yes"


dp = Dispatcher()


def get_bottom_menu_keyboard() -> ReplyKeyboardMarkup:
    return ReplyKeyboardMarkup(
        keyboard=[
            [KeyboardButton(text=RESTART_BUTTON), KeyboardButton(text=HELP_BUTTON)],
        ],
        resize_keyboard=True,
    )


def get_city_inline_keyboard() -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup(
        inline_keyboard=[
            [InlineKeyboardButton(text=CITY_MOSCOW, callback_data="city:moscow")],
            [InlineKeyboardButton(text=MANUAL_CITY_BUTTON, callback_data="city:manual")],
        ]
    )


def normalize_city_name(city_name: str) -> str:
    normalized = city_name.strip().lower()
    aliases = {
        "москва": CITY_MOSCOW_ENGLISH.lower(),
        "moscow": CITY_MOSCOW_ENGLISH.lower(),
    }
    return aliases.get(normalized, normalized)


def build_nominatim_url(city_name: str) -> str:
    params = urlencode(
        {
            "q": city_name,
            "format": "jsonv2",
            "limit": 1,
            "addressdetails": 1,
        }
    )
    return f"{NOMINATIM_SEARCH_URL}?{params}"


def fetch_json(url: str, method: str = "GET", body: bytes | None = None) -> Any:
    headers = {
        "User-Agent": HTTP_USER_AGENT,
        "Accept": "application/json",
    }
    if method == "POST":
        headers["Content-Type"] = "application/x-www-form-urlencoded; charset=utf-8"

    request = Request(
        url,
        data=body,
        method=method,
        headers=headers,
    )
    ssl_context = ssl.create_default_context(cafile=certifi.where())
    with urlopen(request, timeout=30, context=ssl_context) as response:
        return json.loads(response.read().decode("utf-8"))


def get_city_bbox(city_name: str) -> tuple[float, float, float, float]:
    results = fetch_json(build_nominatim_url(city_name))
    if not results:
        raise LookupError("CITY_NOT_FOUND")

    bbox = results[0].get("boundingbox")
    if not bbox or len(bbox) != 4:
        raise LookupError("CITY_BBOX_NOT_FOUND")

    south, north, west, east = bbox
    return float(south), float(west), float(north), float(east)


def build_overpass_query(south: float, west: float, north: float, east: float) -> str:
    bbox = f"{south},{west},{north},{east}"
    return f"""
[out:json][timeout:25];
(
  nwr["amenity"="place_of_worship"]["religion"="jewish"]({bbox});
  nwr["building"="synagogue"]({bbox});
  nwr["synagogue"="yes"]({bbox});
);
out center tags;
"""


def get_element_coordinates(element: dict[str, Any]) -> tuple[float, float] | None:
    if "lat" in element and "lon" in element:
        return float(element["lat"]), float(element["lon"])

    center = element.get("center")
    if center and "lat" in center and "lon" in center:
        return float(center["lat"]), float(center["lon"])

    return None


def is_active_synagogue(tags: dict[str, str]) -> bool:
    inactive_markers = (
        "disused",
        "abandoned",
        "demolished",
        "ruins",
        "was:amenity",
    )
    for marker in inactive_markers:
        if tags.get(marker) == "yes":
            return False
    return True


def parse_synagogues(elements: list[dict[str, Any]]) -> list[SynagoguePlace]:
    unique_places: dict[tuple[str, int], SynagoguePlace] = {}

    for element in elements:
        tags = element.get("tags", {})
        if not tags or not is_active_synagogue(tags):
            continue

        coordinates = get_element_coordinates(element)
        if not coordinates:
            continue

        name = tags.get("name")
        if not name:
            continue

        lat, lon = coordinates
        unique_places[(element["type"], element["id"])] = SynagoguePlace(
            name=name,
            lat=lat,
            lon=lon,
        )

    return sorted(unique_places.values(), key=lambda place: place.name.lower())


def fetch_synagogues_for_city(city_name: str) -> list[SynagoguePlace]:
    south, west, north, east = get_city_bbox(city_name)
    query = build_overpass_query(south, west, north, east)
    response = fetch_json(
        OVERPASS_API_URL,
        method="POST",
        body=urlencode({"data": query}).encode("utf-8"),
    )
    return parse_synagogues(response.get("elements", []))[:MAX_RESULTS]


def build_fetch_error_message(error: Exception) -> str:
    if isinstance(error, LookupError):
        return "Не удалось найти такой город в базе OpenStreetMap. Попробуйте ввести название иначе."

    if isinstance(error, HTTPError):
        return f"Сервис карт вернул ошибку HTTP {error.code}. Попробуйте еще раз чуть позже."

    if isinstance(error, URLError):
        reason = error.reason
        if isinstance(reason, ssl.SSLCertVerificationError):
            return (
                "Python не может проверить SSL-сертификат сервиса карт. "
                "На macOS это обычно решается установкой сертификатов для Python."
            )
        if isinstance(reason, socket.gaierror):
            return "Не удалось разрешить адрес сервиса карт. Проверьте DNS или интернет-соединение."
        return f"Сетевой запрос к сервису карт не удался: {reason}"

    return "Не удалось получить актуальный список синагог. Попробуйте еще раз позже."


def build_synagogues_message(city_name: str, synagogues: list[SynagoguePlace]) -> str:
    lines = [
        f"Актуальные синагоги в городе {city_name}:",
        "",
        "Источник: OpenStreetMap.",
        "",
    ]

    for index, synagogue in enumerate(synagogues, start=1):
        lines.extend(
            [
                f"{index}. {synagogue.name}",
                f"Google Maps: {synagogue.google_maps_url}",
                f"Waze: {synagogue.waze_url}",
                "",
            ]
        )

    return "\n".join(lines).strip()


async def show_city_selection(message: Message, state: FSMContext) -> None:
    await state.set_state(SynagogueFinderStates.choosing_city)
    await message.answer(
        "Шалом! Я помогу найти синагогу в нужном городе.\n"
        "Выберите город из списка или введите его вручную.",
        reply_markup=get_city_inline_keyboard(),
    )


async def send_help_message(message: Message) -> None:
    await message.answer(
        f"По всем вопросам можно связаться: {HELP_CONTACT}",
        reply_markup=get_bottom_menu_keyboard(),
    )


async def send_synagogues_for_city(message: Message, state: FSMContext, city_name: str) -> None:
    await state.set_state(SynagogueFinderStates.choosing_city)
    waiting_message = await message.answer(
        "Ищу актуальные синагоги. Это может занять несколько секунд.",
        reply_markup=get_bottom_menu_keyboard(),
    )

    try:
        synagogues = await asyncio.to_thread(fetch_synagogues_for_city, city_name)
    except Exception as error:
        logging.exception("Failed to fetch synagogues")
        await waiting_message.answer(
            build_fetch_error_message(error),
            reply_markup=get_bottom_menu_keyboard(),
        )
        return

    if not synagogues:
        await waiting_message.answer(
            "В OpenStreetMap не найдено действующих синагог для этого города. Попробуйте другой город или другую форму написания.",
            reply_markup=get_bottom_menu_keyboard(),
        )
        return

    await waiting_message.answer(
        build_synagogues_message(city_name, synagogues),
        reply_markup=get_bottom_menu_keyboard(),
        disable_web_page_preview=True,
    )


@dp.message(CommandStart())
async def handle_start(message: Message, state: FSMContext) -> None:
    await state.clear()
    await show_city_selection(message, state)


@dp.message(F.text == RESTART_BUTTON)
async def handle_restart(message: Message, state: FSMContext) -> None:
    await state.clear()
    await message.answer("Возвращаюсь к выбору города.")
    await show_city_selection(message, state)


@dp.message(F.text == HELP_BUTTON)
async def handle_help(message: Message) -> None:
    await send_help_message(message)


@dp.callback_query(F.data == "city:moscow")
async def handle_city_from_list(callback: CallbackQuery, state: FSMContext) -> None:
    await callback.answer()
    await send_synagogues_for_city(callback.message, state, CITY_MOSCOW_ENGLISH)


@dp.callback_query(F.data == "city:manual")
async def handle_manual_city_request(callback: CallbackQuery, state: FSMContext) -> None:
    await callback.answer()
    await state.set_state(SynagogueFinderStates.entering_city_manually)
    await callback.message.answer(
        'Введите город вручную в формате "Tel Aviv".',
        reply_markup=get_bottom_menu_keyboard(),
    )


@dp.message(SynagogueFinderStates.entering_city_manually, F.text)
async def handle_manual_city_input(message: Message, state: FSMContext) -> None:
    await send_synagogues_for_city(message, state, message.text.strip())


@dp.message(SynagogueFinderStates.choosing_city, F.text)
async def handle_unknown_city_choice(message: Message) -> None:
    await message.answer(
        "Выберите город через inline-кнопки в сообщении выше или нажмите «Начать сначала».",
        reply_markup=get_bottom_menu_keyboard(),
    )


@dp.message()
async def handle_fallback(message: Message, state: FSMContext) -> None:
    current_state = await state.get_state()
    if current_state == SynagogueFinderStates.entering_city_manually.state:
        await message.answer(
            'Введите город текстом, например: "Moscow" или "Tel Aviv".',
            reply_markup=get_bottom_menu_keyboard(),
        )
        return

    await show_city_selection(message, state)


async def main() -> None:
    if not BOT_TOKEN:
        raise RuntimeError(
            "Bot token is not configured. Set SYNAGOGUE_BOT_TOKEN or TELEGRAM_BOT_TOKEN."
        )

    logging.basicConfig(level=logging.INFO)
    bot = Bot(token=BOT_TOKEN)
    await dp.start_polling(bot)


if __name__ == "__main__":
    asyncio.run(main())
